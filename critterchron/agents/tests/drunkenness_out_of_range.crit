# drunkenness_out_of_range.crit: `drunkenness` outside [0.0, 1.0] must be
# rejected at compile time. 1.5 is > 1 — compiler should refuse rather than
# silently clamping at runtime. Matching rejection category: `drunkenness`.
--- colors ---
tortoise: (64, 48, 0)
green:    (0, 255, 0)

--- agents ---
tortoise starts at (0,0)

--- simulation ---
tick rate: 500ms

--- pathfinding ---
tortoise:
  max nodes: 256
  step rate: 1
  drunkenness: 1.5

--- behavior ---
tortoise:
  pause 3
  done
