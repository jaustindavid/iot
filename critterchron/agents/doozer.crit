# doozer.crit: builders and bricks
#
# a "brick" is the agent which manages the brick pile.  
# they count with position and color.  They can accept (incr) or give (decr)
# bricks to doozers.  Their states will be "free", "full", or "busy"
# A "free" pile always has at last one more brick.  A "full" pile can give
# but not accept.  A "busy" pile is occupied right now.
#
# A doozer is a builder.  He visits a free brick pile, which will inspire 
# the pile to shrink or grow.  He builds or demolishes time, brick by brick.

--- colors ---
doozer:  (255, 255, 0)   # yellow
brightyellow:  (255, 255, 0)
dullyellow:  (64, 64, 0)
brick_1:     (50, 0, 0)
brick_2:     (100, 0, 0)
brick_3:     (150, 0, 0)
brick_4:     (200, 0, 0)
brick_5:     (255, 0, 0)
bricks:      (255, 0, 0) # agent body color (required; matches agent name)
brick:       (255, 0, 0) # the tile
black:       (0, 0, 0)

--- landmarks ---
pile_left_floor:   brick
  (0, max_y)
pile_right_floor:  brick
  (max_x, max_y)
piles:             black
  (0, max_y-1)
  (0, max_y-2)
  (0, max_y-3)
  (0, max_y-4)
  (0, max_y-5)
  (max_x, max_y-1)
  (max_x, max_y-2)
  (max_x, max_y-3)
  (max_x, max_y-4)
  (max_x, max_y-5)

--- agents ---
doozer: state { holding, building, dumping, resting }
bricks: state { prepping, free, full, busy }
bricks starts at pile_left_floor, state = prepping
bricks starts at pile_right_floor, state = prepping
doozer starts at (0, 0), state = resting
doozer starts at (1, 0), state = resting

--- simulation ---
tick rate: 250ms

--- pathfinding ---
bricks:
  max nodes: 32
  step rate: 2

doozer:
  max nodes: 2000
  step rate: 1
  diagonal: allowed
  diagonal_cost: 1.414
  penalty lit cell:      30
  penalty occupied cell: 5

--- behavior ---
bricks:
  if state == prepping:
    # build a stack real quick
      step (0, -1)
      draw brick_3
      step (0, -1)
      draw brick_3
      step (0, -1)
      draw brick_3
      step (0, -1)
      draw brick_3
      step (0, -1)
      draw brick_3
      set state = free
  
  if on doozer with state == dumping:
    # accept this brick
    pause
    set state = busy
    if standing on brick_3:
      step (0, -1)
      draw brick_1
      pause
      if not standing on piles:
        set state = full
        done
      set state = free
      done
    if standing on brick_2:
      draw brick_3 
    if standing on brick_1:
      draw brick_2 
    pause
    set state = free
    done

  if on doozer with state == building:
    # give a brick
    pause
    set state = busy
    if standing on brick_1:
      if standing on pile_right_floor:
        # nothing to do; no decrement
        pause
        set state = free
        done
      if standing on pile_left_floor:
        # nothing to do; no decrement
        pause
        set state = free
        done
      # not on the floor; step down
      erase
      step (0, 1)
      set state = free
      done
    if standing on brick_2:
      draw brick_1 
    if standing on brick_3:
      draw brick_2 
    pause
    set state = free
    done

  pause   # terminal: wait 1
  done

doozer:
  if state == holding:
    set color = brightyellow
    # build or dump
    if missing:
      seek missing
      if on missing:
        draw brick
        pause 2
        set state = resting
        done
      wander 
      done
    set state = dumping
    # FALLTHROUGH

  if state == dumping:
    set color = brightyellow
    # return a brick OR ELSE
    seek bricks with state == free
    if on bricks with state == free:
      pause 2  # spend a sec dumping the brick
      set state = resting
    # keep trying until we dump
    wander
    done

  set color = dullyellow

  if extra:
    # grab an extra brick and either build or dump
    seek extra not on piles
    if on extra:
      erase
      pause
      if missing:
        set state = holding
        done
      set state = dumping
      done
    # FALLTHROUGH: failed "extra" seek  

  if missing:
    set state = building
    seek bricks with state == free
    if on bricks with state == free:
      pause 2  # spend a sec getting the brick
      set state = holding
      done

  if random 30%:
    wander avoiding current
  pause
  done
